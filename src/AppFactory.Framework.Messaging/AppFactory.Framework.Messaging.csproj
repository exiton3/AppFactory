<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>AppFactory Framework Shared</Description>
		<PackageTags>AppFactory;Framework;Serverless;SQS</PackageTags>
		<Title>AppFactory Framework Messaging</Title>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE</PackageLicenseFile>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\LICENSE" Link="LICENSE">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
		<None Include="..\..\README.md" Link="README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
  <ItemGroup>
    <PackageReference Include="Amazon.Lambda.Core" Version="3.1.0" />
    <PackageReference Include="Amazon.Lambda.SQSEvents" Version="3.0.0" />
    <PackageReference Include="AppFactory.Framework.DependencyInjection" Version="10.0.1" />
    <PackageReference Include="AppFactory.Framework.Logging" Version="10.0.1" />
    <PackageReference Include="AppFactory.Framework.Shared" Version="10.0.1" />
    <PackageReference Include="AWSSDK.SQS" Version="4.0.2.31" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="10.0.8" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Publishers\" />
  </ItemGroup>

</Project>
