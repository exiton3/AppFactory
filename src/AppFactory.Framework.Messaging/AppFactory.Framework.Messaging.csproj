<Project Sdk="Microsoft.NET.Sdk">
	<PropertyGroup>
		<Description>AppFactory Framework Shared</Description>
		<PackageTags>AppFactory;Framework;Serverless;SQS</PackageTags>
		<Title>AppFactory Framework Messaging</Title>
		<PackageReadmeFile>README.md</PackageReadmeFile>
		<PackageLicenseFile>LICENSE</PackageLicenseFile>
	</PropertyGroup>
	<ItemGroup>
		<None Include="..\..\LICENSE" Link="LICENSE">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
		<None Include="..\..\README.md" Link="README.md">
			<Pack>True</Pack>
			<PackagePath>\</PackagePath>
		</None>
	</ItemGroup>
  <ItemGroup>
    <PackageReference Include="Amazon.Lambda.Core" Version="2.5.0" />
    <PackageReference Include="Amazon.Lambda.SQSEvents" Version="2.2.0" />
    <PackageReference Include="AppFactory.Framework.DependencyInjection" Version="1.0.0" />
    <PackageReference Include="AppFactory.Framework.Logging" Version="1.1.11" />
    <PackageReference Include="AppFactory.Framework.Shared" Version="1.1.12" />
    <PackageReference Include="AWSSDK.SQS" Version="3.7.400.57" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="8.0.0" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="Publishers\" />
  </ItemGroup>

</Project>
